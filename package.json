{
  "name": "coralguard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @coralguard/web run dev",
    "build": "npm --workspace @coralguard/web run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && tsx scripts/run-e2e.ts",
    "demo": "tsx scripts/run-demo-assessment.ts",
    "demo:coral": "tsx scripts/run-coral-live-assessment.ts",
    "check:live-env": "powershell -ExecutionPolicy Bypass -File scripts/check-live-env.ps1",
    "check:live-readiness": "powershell -ExecutionPolicy Bypass -File scripts/check-live-readiness.ps1",
    "check:slack-scopes": "powershell -ExecutionPolicy Bypass -File scripts/check-slack-scopes.ps1",
    "install:live-sources": "powershell -ExecutionPolicy Bypass -File scripts/install-live-sources.ps1",
    "install:live-sources:strict": "powershell -ExecutionPolicy Bypass -File scripts/install-live-sources.ps1 --require-live",
    "import:live-secrets": "powershell -ExecutionPolicy Bypass -File scripts/import-live-secrets-from-clipboard.ps1",
    "set:live-secrets": "powershell -ExecutionPolicy Bypass -File scripts/set-live-secrets.ps1",
    "dev:live": "powershell -ExecutionPolicy Bypass -File scripts/run-live-ui.ps1",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "fastify": "^5.3.3",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.28"
  }
}
